{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/recall.sh",
            "timeout": 20,
            "statusMessage": "Recalling memories..."
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/extract.sh",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
